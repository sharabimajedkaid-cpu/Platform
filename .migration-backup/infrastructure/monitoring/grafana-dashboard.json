{
  "dashboard": {
    "title": "Britishce44 Platform Overview",
    "uid": "britishce44-main",
    "timezone": "browser",
    "panels": [
      {
        "title": "Active Users",
        "type": "stat",
        "datasource": "Prometheus",
        "targets": [{ "expr": "sum(britishce44_active_users)", "legendFormat": "Active Users" }]
      },
      {
        "title": "Active Classrooms",
        "type": "stat",
        "datasource": "Prometheus",
        "targets": [{ "expr": "sum(britishce44_active_classrooms)", "legendFormat": "Active Classrooms" }]
      },
      {
        "title": "API Response Time",
        "type": "graph",
        "datasource": "Prometheus",
        "targets": [{ "expr": "rate(http_request_duration_ms_sum[5m]) / rate(http_request_duration_ms_count[5m])", "legendFormat": "Avg Response" }]
      },
      {
        "title": "WebRTC Streams",
        "type": "stat",
        "datasource": "Prometheus",
        "targets": [{ "expr": "sum(britishce44_webrtc_streams)", "legendFormat": "Active Streams" }]
      },
      {
        "title": "Error Rate",
        "type": "graph",
        "datasource": "Prometheus",
        "targets": [{ "expr": "rate(http_requests_total{status=~\"5..\"}[5m])", "legendFormat": "5xx Errors" }]
      },
      {
        "title": "Messages Sent",
        "type": "stat",
        "datasource": "Prometheus",
        "targets": [{ "expr": "sum(increase(britishce44_messages_total[24h]))", "legendFormat": "24h Messages" }]
      }
    ],
    "tags": ["britishce44", "education", "platform"],
    "schemaVersion": 38
  }
}
