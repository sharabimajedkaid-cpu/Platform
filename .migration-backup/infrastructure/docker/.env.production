# Production
NODE_ENV=production
PORT=3000

# Database
DB_HOST=postgres
DB_PORT=5432
DB_NAME=britishce44
DB_USER=postgres
DB_PASSWORD=changeme_production_password

# Redis
REDIS_URL=redis://redis:6379

# MongoDB
MONGO_URL=mongodb://mongodb:27017/britishce44

# Elasticsearch
ELASTICSEARCH_URL=http://elasticsearch:9200

# JWT
JWT_SECRET=replace_with_secure_random_64_chars
JWT_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d

# TURN/STUN
TURN_SECRET=replace_with_turn_secret
TURN_URLS=turn:coturn:3478,turns:coturn:5349

# Mediasoup
MEDIASOUP_RTC_MIN_PORT=40000
MEDIASOUP_RTC_MAX_PORT=49999
MEDIASOUP_NUM_WORKERS=4
MEDIASOUP_LISTEN_IP=0.0.0.0
MEDIASOUP_ANNOUNCED_IP=YOUR_SERVER_PUBLIC_IP

# AI
OPENAI_API_KEY=sk-your-openai-key-here

# MinIO
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=changeme_minio_password
MINIO_ENDPOINT=minio:9000

# Recording
RECORDING_STORAGE_DIR=/data/recordings

# Frontend
NEXT_PUBLIC_API_URL=http://api-gateway:3000
NEXT_PUBLIC_SIGNALING_URL=http://api-gateway:3000
