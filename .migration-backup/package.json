{
  "name": "britishce44-platform",
  "version": "4.4.0",
  "private": true,
  "description": "Britishce44 Ultimate AI Digital School Ecosystem — Enterprise Educational Platform",
  "workspaces": [
    "backend/services/*",
    "backend/shared",
    "frontend/web",
    "frontend/mobile",
    "frontend/desktop"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev:api-gateway\" \"npm run dev:auth\" \"npm run dev:classroom\" \"npm run dev:lms\" \"npm run dev:messaging\" \"npm run dev:ai\"",
    "dev:api-gateway": "npm run dev -w backend/services/api-gateway",
    "dev:auth": "npm run dev -w backend/services/auth-service",
    "dev:classroom": "npm run dev -w backend/services/classroom-service",
    "dev:lms": "npm run dev -w backend/services/lms-service",
    "dev:messaging": "npm run dev -w backend/services/messaging-service",
    "dev:ai": "npm run dev -w backend/services/ai-orchestrator",
    "dev:web": "npm run dev -w frontend/web",
    "build": "npm run build --workspaces",
    "test": "npm run test --workspaces",
    "lint": "npm run lint --workspaces",
    "docker:build": "docker-compose -f infrastructure/docker/docker-compose.yml build",
    "docker:up": "docker-compose -f infrastructure/docker/docker-compose.yml up -d",
    "docker:down": "docker-compose -f infrastructure/docker/docker-compose.yml down",
    "k8s:deploy": "kubectl apply -f infrastructure/kubernetes/",
    "migrate": "node database/migrations/run.js",
    "seed": "node database/seeds/run.js"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "typescript": "^5.4.0",
    "eslint": "^8.57.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "prettier": "^3.2.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.0"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  }
}
