{
  "name": "@britishce44/desktop",
  "version": "4.4.0",
  "description": "Britishce44 Desktop App — Windows, macOS, Linux",
  "main": "dist/main.js",
  "scripts": {
    "dev": "electron .",
    "build": "tsc && electron-builder",
    "build:win": "tsc && electron-builder --win",
    "build:mac": "tsc && electron-builder --mac",
    "build:linux": "tsc && electron-builder --linux",
    "lint": "eslint src --ext .ts"
  },
  "build": {
    "appId": "edu.britishce44.desktop",
    "productName": "Britishce44",
    "directories": { "output": "release" },
    "files": ["dist/**/*", "public/**/*"],
    "win": { "target": ["nsis"], "icon": "public/icon.ico" },
    "mac": { "target": ["dmg"], "icon": "public/icon.icns" },
    "linux": { "target": ["AppImage", "deb"], "icon": "public/icon.png" },
    "nsis": { "oneClick": false, "allowToChangeInstallationDirectory": true }
  },
  "dependencies": {
    "electron-store": "^8.2.0",
    "electron-updater": "^6.1.0",
    "socket.io-client": "^4.7.0",
    "electron-is-dev": "^2.0.0",
    "node-fetch": "^2.7.0"
  },
  "devDependencies": {
    "electron": "^29.0.0",
    "electron-builder": "^24.13.0",
    "typescript": "^5.4.0",
    "eslint": "^8.57.0",
    "@types/node": "^20.11.0"
  }
}
